{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BPA DataSolution - Process Configuration Schema",
  "description": "Schema para validar configuración de procesos de extracción",
  "type": "object",
  
  "required": ["version", "projects"],
  
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$",
      "description": "Versión del formato de configuración"
    },
    
    "environment": {
      "type": "string",
      "enum": ["development", "staging", "production"],
      "default": "production"
    },
    
    "description": {
      "type": "string"
    },
    
    "last_updated": {
      "type": "string",
      "format": "date"
    },
    
    "projects": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/project"
      }
    },
    
    "global_settings": {
      "type": "object",
      "properties": {
        "log_level": {
          "type": "string",
          "enum": ["DEBUG", "INFO", "WARNING", "ERROR", "CRITICAL"]
        },
        "max_concurrent_executions": {
          "type": "integer",
          "minimum": 1
        },
        "temp_directory": {
          "type": "string"
        },
        "archive_directory": {
          "type": "string"
        }
      }
    },
    
    "environment_variables": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    }
  },
  
  "definitions": {
    "project": {
      "type": "object",
      "required": ["id", "name", "type", "execution", "parameters"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9_-]+$",
          "description": "Identificador único del proyecto (minúsculas, sin espacios)"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": ["sql_export", "api_export", "file_export", "custom"],
          "default": "sql_export"
        },
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "category": {
          "type": "string",
          "description": "Categoría para organizar proyectos"
        },
        
        "execution": {
          "$ref": "#/definitions/execution"
        },
        
        "parameters": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/definitions/parameter"
          }
        },
        
        "outputs": {
          "$ref": "#/definitions/outputs"
        },
        
        "scheduling": {
          "$ref": "#/definitions/scheduling"
        },
        
        "notifications": {
          "$ref": "#/definitions/notifications"
        },
        
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    
    "execution": {
      "type": "object",
      "required": ["script", "workdir"],
      "properties": {
        "extractor": {
          "type": "string",
          "description": "Tipo de extractor a usar"
        },
        "script": {
          "type": "string",
          "description": "Path al script de extracción"
        },
        "workdir": {
          "type": "string",
          "description": "Directorio de trabajo"
        },
        "python": {
          "type": "string",
          "description": "Path al ejecutable Python"
        },
        "timeout_seconds": {
          "type": "integer",
          "minimum": 60,
          "default": 1800
        },
        "retry_count": {
          "type": "integer",
          "minimum": 0,
          "default": 2
        },
        "retry_delay_seconds": {
          "type": "integer",
          "minimum": 1,
          "default": 60
        },
        "env_vars": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    
    "parameter": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["select", "text", "number", "date", "boolean", "multiselect"],
          "description": "Tipo de parámetro"
        },
        "label": {
          "type": "string",
          "description": "Etiqueta para mostrar en UI"
        },
        "description": {
          "type": "string"
        },
        "required": {
          "type": "boolean",
          "default": false
        },
        "default": {
          "description": "Valor por defecto"
        },
        "options": {
          "oneOf": [
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            {
              "type": "object",
              "additionalProperties": true
            }
          ],
          "description": "Opciones disponibles (para select)"
        },
        "placeholder": {
          "type": "string"
        },
        "validation": {
          "type": "object",
          "properties": {
            "pattern": {
              "type": "string",
              "description": "Regex pattern"
            },
            "min": {
              "type": "number"
            },
            "max": {
              "type": "number"
            },
            "min_length": {
              "type": "integer"
            },
            "max_length": {
              "type": "integer"
            }
          }
        }
      }
    },
    
    "outputs": {
      "type": "object",
      "properties": {
        "directory": {
          "type": "string"
        },
        "pattern": {
          "type": "string",
          "description": "Patrón de nombre de archivo (soporta variables como ${TIMESTAMP})"
        },
        "retention_days": {
          "type": "integer",
          "minimum": 1
        },
        "compression": {
          "type": "string",
          "enum": ["none", "gzip", "bzip2", "zip"]
        }
      }
    },
    
    "scheduling": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false
        },
        "scheduler": {
          "type": "string",
          "enum": ["windows_task", "cron", "apscheduler"],
          "default": "apscheduler"
        },
        "expressions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Expresiones CRON o schedule"
        },
        "windows_task": {
          "type": "object",
          "properties": {
            "names": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "default": {
              "type": "string"
            }
          }
        }
      }
    },
    
    "notifications": {
      "type": "object",
      "properties": {
        "on_failure": {
          "$ref": "#/definitions/notification_config"
        },
        "on_success": {
          "$ref": "#/definitions/notification_config"
        }
      }
    },
    
    "notification_config": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "channels": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["email", "slack", "teams", "webhook"]
          }
        },
        "recipients": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
